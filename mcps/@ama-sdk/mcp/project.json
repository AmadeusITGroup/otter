{
  "name": "ama-sdk-mcp",
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "mcps/@ama-sdk/mcp/src",
  "prefix": "o3r",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "outputs": [
        "{projectRoot}/dist/package.json"
      ],
      "options": {
        "script": "postbuild"
      },
      "dependsOn": [
        "compile",
        "expose-resources"
      ]
    },
    "compile": {
      "executor": "nx:run-script",
      "options": {
        "script": "compile"
      }
    },
    "expose-resources": {},
    "test": {},
    "lint": {},
    "prepare-publish": {},
    "publish": {}
  },
  "tags": []
}
