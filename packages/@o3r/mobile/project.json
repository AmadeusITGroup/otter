{
  "name": "mobile",
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/@o3r/mobile/src",
  "prefix": "o3r",
  "targets": {
    "build": {
      "executor": "nx:noop",
      "dependsOn": [
        "build-builders",
        "compile"
      ],
      "options": {
        "tsConfig": "{projectRoot}/tsconfig.build.json"
      }
    },
    "compile": {
      "executor": "@angular-devkit/build-angular:ng-packagr",
      "options": {
        "project": "packages/@o3r/mobile/ng-package.json",
        "tsConfig": "packages/@o3r/mobile/tsconfig.build.json"
      }
    },
    "build-builders": {
      "executor": "nx:run-script",
      "dependsOn": [
        "^build",
        "compile",
        "prepare-build-builders"
      ],
      "outputs": [
        "{projectRoot}/dist/pcloudy",
        "{projectRoot}/dist/schematics/**/*.js",
        "{projectRoot}/dist/schematics/**/*.d.ts",
        "{projectRoot}/dist/schematics/**/*.map",
        "{projectRoot}/build/.tsbuildinfo.builders"
      ],
      "options": {
        "script": "build:builders"
      }
    },
    "lint": {},
    "test": {},
    "prepare-publish": {},
    "publish": {},
    "prepare-build-builders": {},
    "documentation": {}
  },
  "tags": [],
  "namedInputs": {
    "usedExternalDependencies": [
      {
        "externalDependencies": [
          "@angular-devkit/architect",
          "@angular-devkit/build-angular",
          "@angular-devkit/core",
          "@angular-devkit/schematics",
          "@angular/animations",
          "@angular/cli",
          "@angular/common",
          "@angular/compiler",
          "@angular/compiler-cli",
          "@angular/core",
          "@angular/platform-browser",
          "@angular/platform-browser-dynamic",
          "@babel/core",
          "@babel/preset-typescript",
          "@capacitor/browser",
          "@capacitor/core",
          "@capacitor/device",
          "@capacitor/preferences",
          "@compodoc/compodoc",
          "@eslint-community/eslint-plugin-eslint-comments",
          "@ngrx/store",
          "@nx/eslint",
          "@nx/eslint-plugin",
          "@nx/jest",
          "@nx/js",
          "@schematics/angular",
          "@stylistic/eslint-plugin",
          "@types/jest",
          "@types/node",
          "@types/node-fetch",
          "@typescript-eslint/parser",
          "angular-eslint",
          "commander",
          "cpy-cli",
          "eslint",
          "eslint-import-resolver-node",
          "eslint-import-resolver-typescript",
          "eslint-plugin-import",
          "eslint-plugin-import-newlines",
          "eslint-plugin-jest",
          "eslint-plugin-jsdoc",
          "eslint-plugin-prefer-arrow",
          "eslint-plugin-unicorn",
          "eslint-plugin-unused-imports",
          "fast-deep-equal",
          "form-data",
          "globals",
          "jest",
          "jest-environment-jsdom",
          "jest-junit",
          "jest-preset-angular",
          "jest-util",
          "jsdom",
          "jsonc-eslint-parser",
          "node-fetch",
          "nx",
          "rxjs",
          "ts-jest",
          "tslib",
          "type-fest",
          "typescript",
          "typescript-eslint",
          "winston"
        ]
      }
    ]
  }
}
