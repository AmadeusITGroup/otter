  "projectType": "library",
  "sourceRoot": "packages/@o3r/extractors/src",
  "prefix": "o3r",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "outputs": [
        "{projectRoot}/dist/package.json"
      ],
      "options": {
        "script": "postbuild"
      },
      "dependsOn": [
        "build-builders",
        "compile"
      ]
    },
    "prepare-build-builders": {},
    "build-builders": {},
    "compile": {
      "executor": "nx:run-script",
      "options": {
        "script": "build:source"
      },
      "dependsOn": [
        "^build"
      ]
    },
    "lint": {},
    "test": {},
    "test-int": {},
    "prepare-publish": {},
    "publish": {},
    "documentation": {}
  },
