{
  "name": "schematics",
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/@o3r/schematics/src",
  "prefix": "o3r",
  "implicitDependencies": [
    "!core"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "outputs": [
        "{projectRoot}/dist/package.json"
      ],
      "options": {
        "script": "postbuild",
        "tsConfig": "{projectRoot}/tsconfig.build.json"
      },
      "dependsOn": [
        "^build",
        "compile",
        "build-builders",
        "build-cli"
      ]
    },
    "prepare-build-builders": {},
    "build-builders": {},
    "build-cli": {},
    "compile": {
      "executor": "nx:run-script",
      "options": {
        "script": "build:source"
      }
    },
    "lint": {},
    "test": {},
    "prepare-publish": {},
    "publish": {},
    "documentation": {}
  },
  "tags": [],
  "namedInputs": {
    "usedExternalDependencies": [
      {
        "externalDependencies": [
          "@angular-devkit/architect",
          "@angular-devkit/build-angular",
          "@angular-devkit/core",
          "@angular-devkit/schematics",
          "@angular/animations",
          "@angular/cli",
          "@angular/common",
          "@angular/compiler",
          "@angular/compiler-cli",
          "@angular/core",
          "@angular/platform-browser",
          "@angular/platform-browser-dynamic",
          "@babel/core",
          "@babel/preset-typescript",
          "@compodoc/compodoc",
          "@eslint-community/eslint-plugin-eslint-comments",
          "@inquirer/confirm",
          "@nx/eslint",
          "@nx/eslint-plugin",
          "@nx/jest",
          "@nx/js",
          "@schematics/angular",
          "@stylistic/eslint-plugin",
          "@swc/helpers",
          "@types/jest",
          "@types/minimist",
          "@types/node",
          "@types/semver",
          "@typescript-eslint/parser",
          "angular-eslint",
          "chalk",
          "cpy-cli",
          "eslint",
          "eslint-import-resolver-node",
          "eslint-import-resolver-typescript",
          "eslint-plugin-import",
          "eslint-plugin-import-newlines",
          "eslint-plugin-jest",
          "eslint-plugin-jsdoc",
          "eslint-plugin-prefer-arrow",
          "eslint-plugin-unicorn",
          "eslint-plugin-unused-imports",
          "globals",
          "globby",
          "jest",
          "jest-junit",
          "jest-util",
          "jsonc-eslint-parser",
          "jsonschema",
          "minimatch",
          "minimist",
          "nx",
          "rxjs",
          "semver",
          "tiny-editorconfig",
          "ts-jest",
          "tslib",
          "type-fest",
          "typescript",
          "typescript-eslint"
        ]
      }
    ]
  }
}
