{
  "name": "rules-engine",
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/@o3r/rules-engine/src",
  "prefix": "o3r",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "outputs": [
        "{projectRoot}/dist/package.json"
      ],
      "options": {
        "script": "postbuild",
        "tsConfig": "{projectRoot}/tsconfig.build.json"
      },
      "dependsOn": [
        "^build",
        "build-builders",
        "compile",
        "build-fixtures",
        "extract-rules-engine",
        "expose-schemas"
      ]
    },
    "compile": {
      "executor": "@angular-devkit/build-angular:ng-packagr",
      "dependsOn": [
        "^build",
        "prepare"
      ],
      "options": {
        "project": "packages/@o3r/rules-engine/src/ng-package.json",
        "tsConfig": "packages/@o3r/rules-engine/tsconfig.build.json"
      }
    },
    "expose-schemas": {},
    "prepare": {},
    "extract-rules-engine": {
      "executor": "@o3r/rules-engine:extractor",
      "options": {
        "tsConfig": "./packages/@o3r/rules-engine/tsconfig.build.json",
        "outputFactsDirectory": "./packages/@o3r/rules-engine/dist",
        "outputOperatorsDirectory": "./packages/@o3r/rules-engine/dist",
        "operatorFilePatterns": [
          "./packages/@o3r/rules-engine/src/engine/operator/operators/**/*-operators.ts"
        ],
        "factFilePatterns": [
          "./packages/@o3r/rules-engine/src/facts/**/*-facts.ts"
        ]
      },
      "dependsOn": [
        "build-builders"
      ]
    },
    "build-fixtures": {
      "executor": "nx:noop"
    },
    "build-fixtures-jest": {
      "executor": "nx:run-script",
      "options": {
        "script": "build:fixtures:jest"
      }
    },
    "build-fixtures-jasmine": {
      "executor": "nx:run-script",
      "options": {
        "script": "build:fixtures:jasmine"
      }
    },
    "prepare-build-builders": {},
    "build-builders": {},
    "lint": {},
    "test": {},
    "test-int": {},
    "prepare-publish": {},
    "publish": {},
    "documentation": {}
  },
  "tags": [],
  "namedInputs": {
    "usedExternalDependencies": [
      {
        "externalDependencies": [
          "@ampproject/remapping",
          "@angular-devkit/architect",
          "@angular-devkit/build-angular",
          "@angular-devkit/core",
          "@angular-devkit/schematics",
          "@angular/animations",
          "@angular/cli",
          "@angular/common",
          "@angular/compiler",
          "@angular/compiler-cli",
          "@angular/core",
          "@angular/forms",
          "@angular/platform-browser",
          "@angular/platform-browser-dynamic",
          "@babel/core",
          "@babel/preset-typescript",
          "@compodoc/compodoc",
          "@eslint-community/eslint-plugin-eslint-comments",
          "@ngrx/effects",
          "@ngrx/entity",
          "@ngrx/store",
          "@ngx-translate/core",
          "@nx/eslint",
          "@nx/eslint-plugin",
          "@nx/jest",
          "@nx/js",
          "@schematics/angular",
          "@standard-schema/spec",
          "@stylistic/eslint-plugin",
          "@swc/helpers",
          "@types/jasmine",
          "@types/jest",
          "@types/json-schema",
          "@types/node",
          "@types/semver",
          "@typescript-eslint/parser",
          "angular-eslint",
          "cpy-cli",
          "eslint",
          "eslint-import-resolver-node",
          "eslint-import-resolver-typescript",
          "eslint-plugin-import",
          "eslint-plugin-import-newlines",
          "eslint-plugin-jest",
          "eslint-plugin-jsdoc",
          "eslint-plugin-prefer-arrow",
          "eslint-plugin-unicorn",
          "eslint-plugin-unused-imports",
          "globals",
          "globby",
          "isomorphic-fetch",
          "jest",
          "jest-environment-jsdom",
          "jest-junit",
          "jest-preset-angular",
          "jest-util",
          "jsdom",
          "json-schema",
          "jsonc-eslint-parser",
          "jsonpath-plus",
          "memfs",
          "nx",
          "rimraf",
          "rxjs",
          "semver",
          "ts-jest",
          "tslib",
          "type-fest",
          "typescript",
          "typescript-eslint",
          "typescript-json-schema",
          "unionfs"
        ]
      }
    ]
  }
}
