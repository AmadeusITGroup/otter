{
  "name": "ama-sdk-swagger-builder",
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/@ama-sdk/swagger-builder/src",
  "prefix": "o3r",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "outputs": [
        "{projectRoot}/dist/package.json"
      ],
      "options": {
        "script": "postbuild"
      },
      "dependsOn": [
        "compile"
      ]
    },
    "compile": {
      "executor": "nx:run-script",
      "options": {
        "script": "build:source"
      }
    },
    "lint": {},
    "test": {},
    "prepare-publish": {},
    "publish": {}
  },
  "tags": [],
  "namedInputs": {
    "usedExternalDependencies": [
      {
        "externalDependencies": [
          "@angular/cli",
          "@apidevtools/swagger-parser",
          "@eslint-community/eslint-plugin-eslint-comments",
          "@nx/eslint-plugin",
          "@nx/jest",
          "@stylistic/eslint-plugin",
          "@types/jest",
          "@types/js-yaml",
          "@types/node",
          "@types/semver",
          "@types/swagger-schema-official",
          "@typescript-eslint/parser",
          "angular-eslint",
          "commander",
          "concurrently",
          "cpy-cli",
          "eslint",
          "eslint-import-resolver-node",
          "eslint-import-resolver-typescript",
          "eslint-plugin-import",
          "eslint-plugin-import-newlines",
          "eslint-plugin-jest",
          "eslint-plugin-jsdoc",
          "eslint-plugin-prefer-arrow",
          "eslint-plugin-unicorn",
          "eslint-plugin-unused-imports",
          "globals",
          "globby",
          "jest",
          "jest-junit",
          "jest-util",
          "js-yaml",
          "jsonc-eslint-parser",
          "jsonschema",
          "openapi-types",
          "semver",
          "swagger-schema-official",
          "ts-jest",
          "tslib",
          "typescript",
          "typescript-eslint"
        ]
      }
    ]
  }
}
