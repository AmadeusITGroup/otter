{
  "name": "ama-sdk-schematics",
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/@ama-sdk/schematics/src",
  "prefix": "o3r",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "outputs": [
        "{projectRoot}/dist/package.json"
      ],
      "options": {
        "script": "postbuild"
      },
      "dependsOn": [
        "build-builders",
        "build-cli"
      ]
    },
    "prepare-build-builders": {
      "executor": "nx:run-script",
      "options": {
        "script": "prepare:build:builders"
      },
      "inputs": [
        "schematics-only",
        "^cli",
        "{projectRoot}/schematics/**/*.jar"
      ],
      "outputs": [
        "{projectRoot}/dist/package.json",
        "{projectRoot}/dist/migration.json",
        "{projectRoot}/dist/collection.json",
        "{projectRoot}/dist/schematics/**/*.json",
        "{projectRoot}/dist/schematics/**/*.jar",
        "{projectRoot}/dist/schematics/**/templates/**"
      ]
    },
    "build-builders": {
      "executor": "nx:run-script",
      "options": {
        "script": "build:builders"
      },
      "inputs": [
        "schematics",
        "source",
        "^source"
      ],
      "outputs": [
        "{projectRoot}/dist/src/**/*.js",
        "{projectRoot}/dist/src/**/*.d.ts",
        "{projectRoot}/dist/src/**/*.map",
        "{projectRoot}/dist/schematics/package.json",
        "{projectRoot}/dist/schematics/**/*.js",
        "{projectRoot}/dist/schematics/**/*.d.ts",
        "{projectRoot}/dist/schematics/**/*.map",
        "{projectRoot}/build/.tsbuildinfo.builders"
      ]
    },
    "build-cli": {
      "dependsOn": [
        "build-builders",
        "expose-templates"
      ]
    },
    "expose-templates": {},
    "lint": {},
    "test": {},
    "test-int": {
      "options": {
        "passWithNoTests": true
      }
    },
    "prepare-publish": {},
    "publish": {}
  },
  "tags": [],
  "namedInputs": {
    "usedExternalDependencies": [
      {
        "externalDependencies": [
          "@angular-devkit/core",
          "@angular-devkit/schematics",
          "@angular-devkit/schematics-cli",
          "@angular/cli",
          "@eslint-community/eslint-plugin-eslint-comments",
          "@nx/eslint-plugin",
          "@nx/jest",
          "@openapitools/openapi-generator-cli",
          "@schematics/angular",
          "@stylistic/eslint-plugin",
          "@types/ejs",
          "@types/jest",
          "@types/js-yaml",
          "@types/minimist",
          "@types/node",
          "@types/semver",
          "@typescript-eslint/parser",
          "angular-eslint",
          "chokidar",
          "commit-and-tag-version",
          "cpy-cli",
          "ejs",
          "eslint",
          "eslint-import-resolver-node",
          "eslint-import-resolver-typescript",
          "eslint-plugin-import",
          "eslint-plugin-import-newlines",
          "eslint-plugin-jest",
          "eslint-plugin-jsdoc",
          "eslint-plugin-prefer-arrow",
          "eslint-plugin-unicorn",
          "eslint-plugin-unused-imports",
          "globals",
          "globby",
          "isomorphic-fetch",
          "jest",
          "jest-junit",
          "jest-util",
          "js-yaml",
          "jsonc-eslint-parser",
          "mem-fs",
          "minimatch",
          "minimist",
          "npm-run-all2",
          "nx",
          "openapi-types",
          "rxjs",
          "semver",
          "ts-jest",
          "tslib",
          "type-fest",
          "typescript",
          "typescript-eslint"
        ]
      }
    ]
  }
}
