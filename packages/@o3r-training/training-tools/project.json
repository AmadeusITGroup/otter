{
  "name": "training-tools",
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/@o3r-training/training-tools/src",
  "prefix": "o3r",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "outputs": [
        "{projectRoot}/dist/package.json"
      ],
      "options": {
        "script": "postbuild"
      },
      "dependsOn": [
        "^build",
        "compile",
        "build-builders",
        "build-cli"
      ]
    },
    "prepare-build-builders": {},
    "build-builders": {},
    "build-cli": {},
    "compile": {
      "executor": "nx:run-script",
      "options": {
        "script": "build:source"
      }
    },
    "lint": {},
    "test": {}
  },
  "tags": [
    "access:private"
  ],
  "namedInputs": {
    "usedExternalDependencies": [
      {
        "externalDependencies": [
          "@angular-devkit/build-angular",
          "@angular-devkit/core",
          "@angular-devkit/schematics",
          "@angular/animations",
          "@angular/cli",
          "@angular/common",
          "@angular/compiler",
          "@angular/compiler-cli",
          "@angular/core",
          "@angular/platform-browser",
          "@angular/platform-browser-dynamic",
          "@babel/core",
          "@babel/preset-typescript",
          "@eslint-community/eslint-plugin-eslint-comments",
          "@nx/eslint",
          "@nx/eslint-plugin",
          "@nx/jest",
          "@nx/js",
          "@schematics/angular",
          "@stylistic/eslint-plugin",
          "@swc/cli",
          "@swc/core",
          "@swc/helpers",
          "@types/jest",
          "@types/node",
          "@types/semver",
          "@typescript-eslint/parser",
          "@webcontainer/api",
          "angular-eslint",
          "commander",
          "cpy-cli",
          "eslint",
          "eslint-plugin-import",
          "eslint-plugin-import-newlines",
          "eslint-plugin-jest",
          "eslint-plugin-jsdoc",
          "eslint-plugin-prefer-arrow",
          "eslint-plugin-unicorn",
          "eslint-plugin-unused-imports",
          "jest",
          "jest-junit",
          "jest-util",
          "jsonc-eslint-parser",
          "jsonschema",
          "nx",
          "rxjs",
          "ts-jest",
          "tslib",
          "type-fest",
          "typescript",
          "typescript-eslint"
        ]
      }
    ]
  }
}
