{
  "name": "training-sdk",
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/@o3r-training/training-sdk/src",
  "prefix": "o3r",
  "targets": {
    "build": {
      "executor": "nx:noop",
      "dependsOn": [
        "compile",
        "extract-folder-structure"
      ]
    },
    "compile": {
      "executor": "nx:run-script",
      "options": {
        "script": "build"
      },
      "inputs": [
        "source",
        "^cli"
      ]
    },
    "regen": {},
    "lint": {},
    "extract-folder-structure": {
      "cache": true,
      "executor": "nx:run-script",
      "options": {
        "script": "extract"
      },
      "inputs": [
        "source",
        "^cli",
        "{projectRoot}/package.json",
        "{projectRoot}/open-api.yaml"
      ],
      "outputs": [
        "{projectRoot}/dist/structure"
      ],
      "dependsOn": [
        "^build",
        "compile"
      ]
    }
  },
  "tags": [],
  "namedInputs": {
    "usedExternalDependencies": [
      {
        "externalDependencies": [
          "@angular-devkit/core",
          "@angular-devkit/schematics",
          "@angular-devkit/schematics-cli",
          "@angular/cli",
          "@angular/compiler",
          "@commitlint/cli",
          "@commitlint/config-conventional",
          "@eslint-community/eslint-plugin-eslint-comments",
          "@nx/eslint-plugin",
          "@openapitools/openapi-generator-cli",
          "@schematics/angular",
          "@stylistic/eslint-plugin",
          "@swc/cli",
          "@swc/core",
          "@swc/helpers",
          "@types/jest",
          "@types/node",
          "@typescript-eslint/parser",
          "angular-eslint",
          "commit-and-tag-version",
          "cpy-cli",
          "eslint",
          "eslint-plugin-import",
          "eslint-plugin-import-newlines",
          "eslint-plugin-jest",
          "eslint-plugin-jsdoc",
          "eslint-plugin-prefer-arrow",
          "eslint-plugin-unicorn",
          "eslint-plugin-unused-imports",
          "globals",
          "globby",
          "isomorphic-fetch",
          "jest",
          "jest-junit",
          "jest-util",
          "jsonc-eslint-parser",
          "lint-staged",
          "minimist",
          "rimraf",
          "rxjs",
          "ts-jest",
          "tsc-watch",
          "tslib",
          "typescript",
          "typescript-eslint",
          "yaml-eslint-parser"
        ]
      }
    ]
  }
}
