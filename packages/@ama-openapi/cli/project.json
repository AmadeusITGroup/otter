{
  "name": "ama-openapi-cli",
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/@ama-openapi/cli/src",
  "prefix": "ama",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "outputs": [
        "{projectRoot}/dist/package.json"
      ],
      "options": {
        "script": "postbuild"
      },
      "dependsOn": [
        "^build",
        "compile"
      ]
    },
    "compile": {
      "executor": "nx:run-script",
      "options": {
        "script": "build:source"
      }
    },
    "lint": {},
    "test": {
      "plugin": "@nx/vitest",
      "executor": "@nx/vitest:test",
      "inputs": [
        {
          "env": "RUNNER_OS"
        },
        "builders",
        "schematics",
        "source",
        "tests"
      ],
      "outputs": [
        "{projectRoot}/dist-test/junit.xml",
        "{projectRoot}/coverage/cobertura-coverage.xml"
      ],
      "dependsOn": []
    },
    "set-version": {},
    "prepare-publish": {},
    "publish": {}
  },
  "tags": []
}
