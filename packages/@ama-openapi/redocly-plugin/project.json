{
  "name": "ama-openapi-redocly-plugin",
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/@ama-openapi/redocly-plugin/src",
  "prefix": "ama",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "outputs": [
        "{projectRoot}/dist/package.json"
      ],
      "options": {
        "script": "postbuild"
      },
      "dependsOn": [
        "^build",
        "compile"
      ]
    },
    "compile": {
      "executor": "nx:run-script",
      "options": {
        "script": "build:source"
      }
    },
    "lint": {},
    "test": {
      "plugin": "@nx/vitest",
      "executor": "@nx/vitest:test",
      "inputs": [
        {
          "env": "RUNNER_OS"
        },
        "builders",
        "schematics",
        "source",
        "tests"
      ],
      "outputs": [
        "{projectRoot}/dist-test/junit.xml",
        "{projectRoot}/coverage/cobertura-coverage.xml"
      ],
      "dependsOn": []
    },
    "prepare-publish": {},
    "publish": {},
    "documentation": {}
  },
  "tags": [],
  "namedInputs": {
    "usedExternalDependencies": [
      {
        "externalDependencies": [
          "@angular/cli",
          "@compodoc/compodoc",
          "@eslint-community/eslint-plugin-eslint-comments",
          "@nx/eslint",
          "@nx/eslint-plugin",
          "@nx/js",
          "@nx/vitest",
          "@redocly/openapi-core",
          "@stylistic/eslint-plugin",
          "@types/minimist",
          "@types/node",
          "@types/semver",
          "@types/yargs",
          "@typescript-eslint/parser",
          "@vitest/coverage-istanbul",
          "angular-eslint",
          "cpy-cli",
          "dotenv",
          "eslint",
          "eslint-import-resolver-node",
          "eslint-import-resolver-typescript",
          "eslint-plugin-import",
          "eslint-plugin-import-newlines",
          "eslint-plugin-jsdoc",
          "eslint-plugin-prefer-arrow",
          "eslint-plugin-unicorn",
          "eslint-plugin-unused-imports",
          "globals",
          "jsonc-eslint-parser",
          "nx",
          "tslib",
          "typescript",
          "typescript-eslint",
          "vitest",
          "yargs"
        ]
      }
    ]
  }
}
