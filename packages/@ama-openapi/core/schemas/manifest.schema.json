{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenApi specification package manifest",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the current OpenAPI collection"
    },
    "dependencyOutput": {
      "type": "string",
      "description": "Folder where download the dependency models",
      "default": "./oas_external"
    },
    "registry": {
      "$ref": "#/definitions/registry",
      "description": "Default Registry URL"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/dependency"
      }
    }
  },
  "definitions": {
    "registry": {
      "type": "string",
      "description": "Registry URL to get the dependency to"
    },
    "mask": {
      "type": "object",
      "properties": {
        "properties": {
          "type": "object"
        }
      }
    },
    "model": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the definition model as used in the specification"
        },
        "source": {
          "type": "string",
          "description": "Model path in the dependency artifact"
        },
        "mask": {
          "$ref": "#/definitions/mask"
        }
      },
      "required": [
        "source"
      ]
    },
    "dependencyLink": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the definition as used in the specification"
        },
        "link": {
          "type": "string",
          "description": "URL to the model to link"
        },
        "mask": {
          "$ref": "#/definitions/mask"
        }
      },
      "required": [
        "link"
      ],
      "additionalProperties": false
    },
    "dependencyArtifact": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the definition as used in the specification"
        },
        "artifact": {
          "type": "string",
          "description": "Name of the artifact of the registry"
        },
        "version": {
          "type": "string",
          "description": "Version of the specification"
        },
        "models": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/model"
          },
          "description": "List of the models to be referable in the current specification"
        },
        "registry": {
          "$ref": "#/definitions/registry",
          "description": "Registry URL for the dependency"
        }
      },
      "required": [
        "artifact",
        "version",
        "models"
      ],
      "additionalProperties": false
    },
    "dependency": {
      "oneOf": [
        {
          "$ref": "#/definitions/dependencyLink"
        },
        {
          "$ref": "#/definitions/dependencyArtifact"
        }
      ]
    }
  }
}
