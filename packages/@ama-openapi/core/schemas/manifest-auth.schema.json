{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Registry identification",
  "type": "object",
  "properties": {
    "registries": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/registry"
      }
    }
  },
  "required": [
    "registries"
  ],
  "definitions": {
    "registry": {
      "allOf": [
        {
          "type": "object",
          "properties": {
            "url": {
              "type": "string"
            }
          },
          "required": [
            "url"
          ]
        },
        {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "authToken": {
                  "type": "string"
                }
              },
              "required": [
                "authToken"
              ]
            },
            {
              "type": "object",
              "properties": {
                "user": {
                  "type": "string"
                },
                "password": {
                  "type": "string"
                }
              },
              "required": [
                "password"
              ]
            }
          ]
        }
      ]
    }
  }
}
