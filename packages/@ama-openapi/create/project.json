{
  "name": "ama-openapi-create",
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/@ama-openapi/create/src",
  "prefix": "o3r",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "outputs": [
        "{projectRoot}/dist/package.json"
      ],
      "options": {
        "script": "postbuild"
      },
      "dependsOn": [
        "compile",
        "expose-templates"
      ]
    },
    "expose-templates": {},
    "compile": {
      "executor": "nx:run-script",
      "outputs": [
        "{projectRoot}/dist/index.*"
      ],
      "options": {
        "script": "compile"
      },
      "dependsOn": [
        "^build"
      ]
    },
    "lint": {},
    "prepare-publish": {},
    "publish": {}
  },
  "tags": [],
  "namedInputs": {
    "usedExternalDependencies": [
      {
        "externalDependencies": [
          "@angular-devkit/schematics",
          "@angular/cli",
          "@eslint-community/eslint-plugin-eslint-comments",
          "@nx/eslint",
          "@nx/eslint-plugin",
          "@nx/jest",
          "@nx/js",
          "@schematics/angular",
          "@stylistic/eslint-plugin",
          "@types/ejs",
          "@types/jest",
          "@types/minimist",
          "@types/node",
          "@types/semver",
          "@types/yargs",
          "@typescript-eslint/parser",
          "angular-eslint",
          "cpy-cli",
          "ejs",
          "eslint",
          "eslint-import-resolver-node",
          "eslint-import-resolver-typescript",
          "eslint-plugin-import",
          "eslint-plugin-import-newlines",
          "eslint-plugin-jest",
          "eslint-plugin-jsdoc",
          "eslint-plugin-prefer-arrow",
          "eslint-plugin-unicorn",
          "eslint-plugin-unused-imports",
          "globals",
          "globby",
          "jest",
          "jest-junit",
          "jest-util",
          "jsonc-eslint-parser",
          "nx",
          "rimraf",
          "rxjs",
          "semver",
          "ts-jest",
          "tslib",
          "type-fest",
          "typescript",
          "typescript-eslint",
          "yargs"
        ]
      }
    ]
  }
}
