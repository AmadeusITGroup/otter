{
  "name": "@ama-openapi/mcp",
  "version": "0.0.0-placeholder",
  "publishConfig": {
    "access": "public"
  },
  "description": "Experimental package -- MCP server to expose OpenAPI specifications to AI assistants",
  "keywords": [
    "mcp",
    "openapi",
    "ai-context",
    "otter-module"
  ],
  "main": "./src/public_api.ts",
  "sideEffects": false,
  "bin": {
    "ama-openapi-mcp": "./dist/src/cli.js"
  },
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./dist/src/public_api.d.ts",
      "default": "./dist/src/public_api.js"
    }
  },
  "scripts": {
    "nx": "nx",
    "ng": "yarn nx",
    "build": "yarn nx build ama-openapi-mcp",
    "compile": "tsc -b ./tsconfig.build.json && yarn cpy package.json dist && patch-package-json-main"
  },
  "dependencies": {
    "@ama-mcp/core": "workspace:~",
    "@ama-openapi/core": "workspace:~",
    "@modelcontextprotocol/sdk": "~1.28.0",
    "@o3r/telemetry": "workspace:~",
    "tslib": "^2.6.2",
    "zod": "~4.3.0"
  },
  "devDependencies": {
    "@ama-mcp/core": "workspace:~",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.4.0",
    "@modelcontextprotocol/sdk": "~1.28.0",
    "@nx/eslint": "~22.6.0",
    "@nx/eslint-plugin": "~22.6.0",
    "@nx/js": "~22.6.0",
    "@nx/vitest": "~22.6.0",
    "@o3r/build-helpers": "workspace:^",
    "@o3r/eslint-config": "workspace:^",
    "@o3r/eslint-plugin": "workspace:^",
    "@o3r/test-helpers": "workspace:^",
    "@stylistic/eslint-plugin": "~5.10.0",
    "@types/node": "~24.12.0",
    "@typescript-eslint/parser": "~8.58.0",
    "@vitest/coverage-istanbul": "^4.0.18",
    "cpy-cli": "^6.0.0",
    "eslint": "~9.39.0",
    "eslint-import-resolver-node": "~0.3.9",
    "eslint-import-resolver-typescript": "~4.4.0",
    "eslint-plugin-import": "~2.32.0",
    "eslint-plugin-import-newlines": "~1.4.0",
    "eslint-plugin-jest": "~29.15.0",
    "eslint-plugin-jsdoc": "~61.7.0",
    "eslint-plugin-prefer-arrow": "~1.2.3",
    "eslint-plugin-unicorn": "~62.0.0",
    "eslint-plugin-unused-imports": "~4.4.0",
    "globals": "^16.0.0",
    "jsonc-eslint-parser": "~2.4.0",
    "type-fest": "^5.3.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "~8.58.0",
    "vitest": "~4.1.0",
    "zod": "~4.3.0"
  },
  "peerDependencies": {
    "type-fest": "^5.3.1"
  },
  "peerDependenciesMeta": {
    "type-fest": {
      "optional": true
    }
  },
  "engines": {
    "node": "^22.17.0 || ^24.0.0"
  }
}
