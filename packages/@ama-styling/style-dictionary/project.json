{
  "name": "ama-style-dictionary",
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/@ama-styling/style-dictionary/src",
  "prefix": "ama",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "outputs": [
        "{projectRoot}/dist/package.json"
      ],
      "options": {
        "script": "postbuild"
      },
      "dependsOn": [
        "^build",
        "compile",
        "expose-schemas",
        "build-builders"
      ]
    },
    "expose-schemas": {},
    "compile": {
      "executor": "nx:run-script",
      "options": {
        "script": "build:source"
      }
    },
    "lint": {},
    "vitest": {
      "plugin": "@nx/vitest"
    },
    "test": {
      "executor": "nx:noop",
      "dependsOn": [
        "vitest"
      ]
    },
    "test-int": {
      "options": {
        "jestConfig": "{projectRoot}/testing/jest.config.it.cjs"
      }
    },
    "prepare-build-builders": {},
    "build-builders": {},
    "prepare-publish": {},
    "publish": {},
    "documentation": {}
  },
  "tags": [],
  "namedInputs": {
    "usedExternalDependencies": [
      {
        "externalDependencies": [
          "@angular-devkit/architect",
          "@angular-devkit/schematics",
          "@angular/cli",
          "@compodoc/compodoc",
          "@eslint-community/eslint-plugin-eslint-comments",
          "@nx/eslint",
          "@nx/eslint-plugin",
          "@nx/jest",
          "@nx/js",
          "@nx/vitest",
          "@schematics/angular",
          "@stylistic/eslint-plugin",
          "@types/jest",
          "@types/minimist",
          "@types/node",
          "@types/semver",
          "@typescript-eslint/parser",
          "@vitest/coverage-istanbul",
          "angular-eslint",
          "chokidar",
          "cpy-cli",
          "eslint",
          "eslint-import-resolver-node",
          "eslint-import-resolver-typescript",
          "eslint-plugin-import",
          "eslint-plugin-import-newlines",
          "eslint-plugin-jest",
          "eslint-plugin-jsdoc",
          "eslint-plugin-prefer-arrow",
          "eslint-plugin-unicorn",
          "eslint-plugin-unused-imports",
          "globals",
          "jest",
          "jest-junit",
          "jest-resolve",
          "jest-util",
          "jsonc-eslint-parser",
          "nx",
          "style-dictionary",
          "ts-jest",
          "tslib",
          "type-fest",
          "typescript",
          "typescript-eslint",
          "vitest"
        ]
      }
    ]
  }
}
