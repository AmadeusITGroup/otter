{
  "name": "ama-stylelint-plugin",
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/@ama-styling/stylelint-plugin/src",
  "prefix": "o3r",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "outputs": ["{projectRoot}/dist/package.json"],
      "options": {
        "script": "postbuild"
      },
      "dependsOn": ["compile", "build-builders"]
    },
    "prepare-build-builders": {},
    "build-builders": {},
    "compile": {
      "executor": "nx:run-script",
      "outputs": [
        "{projectRoot}/dist/**/*.mjs",
        "{projectRoot}/dist/**/*.d.mts",
        "{projectRoot}/dist/**/*.map"
      ],
      "options": {
        "script": "build:source"
      },
      "dependsOn": ["^build"]
    },
    "lint": {},
    "test": {
      "plugin": "@nx/vitest",
      "executor": "@nx/vitest:test",
      "inputs": [
        {
          "env": "RUNNER_OS"
        },
        "builders",
        "schematics",
        "source",
        "tests"
      ],
      "outputs": [
        "{projectRoot}/dist-test/junit.xml",
        "{projectRoot}/coverage/cobertura-coverage.xml"
      ],
      "dependsOn": []
    },
    "test-int": {},
    "prepare-publish": {},
    "publish": {},
    "documentation": {}
  },
  "tags": []
}
