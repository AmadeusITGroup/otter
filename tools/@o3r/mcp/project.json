{
  "name": "mcp",
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/@o3r/mcp/src",
  "prefix": "o3r",
  "targets": {
    "build": {
      "executor": "nx:noop",
      "dependsOn": ["compile"]
    },
    "compile": {
      "executor": "nx:run-script",
      "options": {
        "script": "compile"
      },
      "dependsOn": ["prepare", "^build"]
    },
    "test": {},
    "lint": {},
    "deepeval": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "tools/@o3r/mcp/evals",
        "commands": [
          "pip install -r requirements.lock",
          "deepeval test run ."
        ],
        "parallel": false
      },
      "dependsOn": ["build"]
    },
    "prepare-publish": {},
    "publish": {}
  },
  "tags": []
}
