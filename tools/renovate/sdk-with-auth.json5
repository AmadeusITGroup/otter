{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Usage: 'github>AmadeusITGroup/otter//tools/renovate/sdk-with-auth(//npm.my-company.example/api/npm/npm/, NPM_AUTH_BASE64)' - Group all otter dependencies and trigger SDK regeneration with yarn, with private registry authentication. arg0: scheme-less registry URL with trailing slash (e.g. '//npm.my-company.example/api/npm/npm/'). arg1: name of the environment variable holding the base64-encoded token (e.g. 'NPM_AUTH_BASE64'); must be exposed to Renovate via customEnvVariables.",
  "extends": [
    "github>AmadeusITGroup/otter//tools/renovate/group/otter",
    "github>AmadeusITGroup/otter//tools/renovate/tasks/base-with-auth.json5({{arg0}}, {{arg1}})",
    "github>AmadeusITGroup/otter//tools/renovate/branching-strategy/release-branches",
    "github>AmadeusITGroup/otter//tools/renovate/tasks/sdk-regenerate-with-auth.json5(yarn, {{arg0}}, {{arg1}})",
    "github>AmadeusITGroup/otter//tools/renovate/tasks/yarn-pnp"
  ]
}
