{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Trigger post install scripts when updating package manager. arg0: optional npm config file path (only supported for npm and Yarn 1 via NPM_CONFIG_USERCONFIG; for Yarn 2+, configure hostRules instead, see https://docs.renovatebot.com/getting-started/private-packages/#yarn-2).",
  "packageRules": [
    {
      "matchDepTypes": [
        "packageManager"
      ],
      "matchPackageNames": [
        "npm"
      ],
      "postUpgradeTasks": {
        "commands": [
          "{{#if (equals '{{arg0}}' '')}}npm install{{else}}NPM_CONFIG_USERCONFIG={{arg0}} npm install{{/if}}"
        ],
        "executionMode": "branch",
        "fileFilters": [
          "packages/**/package.json",
          "packages/**/package.json.template",
          "package.json"
        ]
      },
      "rangeStrategy": "auto",
      "groupName": "Package manager",
      "groupSlug": "package-manager"
    },
    {
      "matchDepTypes": [
        "packageManager"
      ],
      "matchPackageNames": [
        "yarn"
      ],
      "postUpgradeTasks": {
        "commands": [
          "{{#if (equals '{{arg0}}' '')}}yarn install{{else}}NPM_CONFIG_USERCONFIG={{arg0}} yarn install{{/if}}"
        ],
        "executionMode": "branch",
        "fileFilters": [
          "packages/**/package.json",
          "packages/**/package.json.template",
          "package.json"
        ]
      }
    }
  ]
}
