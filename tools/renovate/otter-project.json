{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Group all otter dependencies and trigger ng update scripts with yarn. arg0: optional npm config file path for private registry support (only npm/Yarn 1 via NPM_CONFIG_USERCONFIG; for Yarn 2+, use hostRules).",
  "extends": [
    "github>AmadeusITGroup/otter//tools/renovate/group/otter",
    "github>AmadeusITGroup/otter//tools/renovate/group/mfe",
    "github>AmadeusITGroup/otter//tools/renovate/tasks/base({{arg0}})",
    "github>AmadeusITGroup/otter//tools/renovate/branching-strategy/release-branches",
    "github>AmadeusITGroup/otter//tools/renovate/tasks/otter-ng-update(yarn, {{arg0}})",
    "github>AmadeusITGroup/otter//tools/renovate/tasks/yarn-pnp",
    "github>AmadeusITGroup/otter//tools/renovate/managers/renovate-otter-presets.json5"
  ]
}
